rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }
    function ownsShop(shopId) {
      return signedIn() && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
    }
    function isEmployee(shopId) {
      return signedIn() && exists(/databases/$(database)/documents/shops/$(shopId)/employees/$(request.auth.uid));
    }
    function hasShopAccess(shopId) { return isAdmin() || ownsShop(shopId) || isEmployee(shopId); }
    function canDiscount(shopId) {
      return isAdmin() || ownsShop(shopId) || (isEmployee(shopId)
        && get(/databases/$(database)/documents/shops/$(shopId)/employees/$(request.auth.uid)).data.permissions.discount == true);
    }
    function validMoney(value) { return value is number && value >= 0 && value < 100000000000; }

    match /users/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create: if isAdmin() || (ownsShop(request.resource.data.shopId) && request.resource.data.role == 'EMPLOYEE');
      allow update: if isAdmin() || ownsShop(resource.data.shopId);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /shops/{shopId} {
      allow read: if hasShopAccess(shopId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (ownsShop(shopId)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'address', 'businessType', 'updatedAt']));

      match /products/{productId} {
        allow read: if hasShopAccess(shopId);
        allow create: if (isAdmin() || ownsShop(shopId))
          && request.resource.data.shopId == shopId
          && request.resource.data.name is string
          && validMoney(request.resource.data.price)
          && request.resource.data.stock is number && request.resource.data.stock >= 0;
        allow update: if (isAdmin() || ownsShop(shopId) || (isEmployee(shopId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'status'])))
          && request.resource.data.shopId == shopId
          && request.resource.data.name is string
          && validMoney(request.resource.data.price)
          && request.resource.data.stock is number && request.resource.data.stock >= 0;
        allow delete: if isAdmin() || ownsShop(shopId);
      }

      match /employees/{employeeId} {
        allow read: if hasShopAccess(shopId);
        allow create, update, delete: if isAdmin() || ownsShop(shopId);
      }

      match /orders/{orderId} {
        allow read: if hasShopAccess(shopId);
        allow create: if hasShopAccess(shopId)
          && request.resource.data.shopId == shopId
          && validMoney(request.resource.data.total)
          && request.resource.data.items is list
          && (request.resource.data.discount == 0 || canDiscount(shopId));
        allow update: if isAdmin() || ownsShop(shopId) || (isEmployee(shopId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
        allow delete: if isAdmin();
      }

      match /customers/{customerId} {
        allow read, create, update: if hasShopAccess(shopId);
        allow delete: if isAdmin() || ownsShop(shopId);
      }

      match /shifts/{shiftId} {
        allow read: if hasShopAccess(shopId);
        allow create: if hasShopAccess(shopId) && request.resource.data.employeeId == request.auth.uid;
        allow update: if isAdmin() || ownsShop(shopId) || resource.data.employeeId == request.auth.uid;
      }

      match /settings/{settingId} {
        allow read, write: if isAdmin() || ownsShop(shopId);
      }

      match /paymentAccounts/{accountId} {
        allow read: if hasShopAccess(shopId);
        allow create, update, delete: if isAdmin() || ownsShop(shopId);
      }

      match /suppliers/{supplierId} {
        allow read: if hasShopAccess(shopId);
        allow create, update, delete: if isAdmin() || ownsShop(shopId);
      }

      match /purchases/{purchaseId} {
        allow read: if hasShopAccess(shopId);
        allow create, update, delete: if isAdmin() || ownsShop(shopId);
      }

      match /expenses/{expenseId} {
        allow read: if isAdmin() || ownsShop(shopId);
        allow create, update, delete: if isAdmin() || ownsShop(shopId);
      }

      match /stockMovements/{movementId} {
        allow read: if hasShopAccess(shopId);
        allow create: if hasShopAccess(shopId) && request.resource.data.shopId == shopId;
        allow update, delete: if isAdmin() || ownsShop(shopId);
      }

      match /auditLogs/{logId} {
        allow read: if isAdmin() || ownsShop(shopId);
        allow create: if hasShopAccess(shopId) && request.resource.data.actorId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /{document=**} { allow read, write: if false; }
  }
}
